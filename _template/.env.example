# Copy to `.env.local` (gitignored) and fill in the value.
#
# Read SERVER-SIDE ONLY — by the Vite dev proxy (vite.config.ts) and
# scripts/test-anthropic.mjs. Do NOT add a VITE_ prefix: that would expose the
# key in the client bundle. Sketch code reaches Claude through the same-origin
# /api/anthropic proxy, which injects this key, so the browser never sees it.
ANTHROPIC_API_KEY=
